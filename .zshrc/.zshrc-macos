# ==============================================================================
# 1. MOTOR ASÍNCRONO (ZINIT)
# ==============================================================================
ZINIT_HOME="${HOME}/.local/share/zinit/zinit.git"
[[ ! -d $ZINIT_HOME ]] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

# ==============================================================================
# 2. PLUGINS CORE
# ==============================================================================
zinit light-mode for \
    OMZL::git.zsh \
    OMZL::history.zsh \
    OMZL::key-bindings.zsh \
    OMZL::completion.zsh \
    OMZP::git \
    zdharma-continuum/fast-syntax-highlighting \
    zsh-users/zsh-autosuggestions


# ==============================================================================
# 3. VARIABLES DE ENTORNO Y PATHS (Universal: Intel & Apple Silicon)
# ==============================================================================
export LANG=es_ES.UTF-8
export EDITOR='nvim'
export GOPATH="$HOME/.local/share/go"

# Inicialización dinámica de Homebrew según arquitectura
if [[ -f "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f "/usr/local/bin/brew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# PATH único y jerárquico
# Prioridad: Scripts personales > Binarios Brew > Otros binarios específicos > $PATH
export PATH="$HOME/.scripts:${HOMEBREW_PREFIX}/bin:${HOMEBREW_PREFIX}/sbin:${HOMEBREW_PREFIX}/opt/openjdk/bin:${HOMEBREW_PREFIX}/opt/sqlite/bin:$PATH"

[[ -f "$HOME/.zshrc_private" ]] && source "$HOME/.zshrc_private"
[[ -f "$HOME/.ls_themes.zsh" ]] && source "$HOME/.ls_themes.zsh"
set_ls_theme "neon"

# ==============================================================================
# 4. ALIAS Y EDITOR
# ==============================================================================
# --- Motor de Edición Global ---
export EDITOR="nvim"
export VISUAL="$EDITOR"

# --- Alias de Aplicaciones ---
alias vim="$EDITOR"
alias v="$EDITOR"
alias ls='lsd'
alias x='exit'
alias tx='tmux'
alias zj='zellij'
alias gitalias="git config --global --get-regexp alias"

# --- Navegación de Directorios (Basados en lsd) ---
alias l='ls -ltr'
alias la='ls -lad .*'
alias l.='ls -d .*'        # lsd ya maneja archivos ocultos de forma más limpia
alias lt='ls --tree'

# --- Herramientas GRC ---
[[ -f "${HOMEBREW_PREFIX}/etc/grc.zsh" ]] && source "${HOMEBREW_PREFIX}/etc/grc.zsh"
# Comprobar si grc e ip existen antes de definir el alias
if (( $+commands[grc] )) && (( $+commands[ip] )); then
    alias ip="grc ip"
fi
# ==============================================================================
# 5. CARGA DIFERIDA (TURBO MODE)
# ==============================================================================
zinit wait'0' lucid for \
    atinit'eval "$(zoxide init --cmd cd zsh)"' \
    atinit'eval "$(atuin init zsh)"' \
    atinit'eval "$(fnm env --use-on-cd --shell zsh)"' \
    zdharma-continuum/null

# ==============================================================================
# 6. PROMPT Y HOOKS FINALES (LIMPIO)
# ==============================================================================
if command -v starship &> /dev/null; then
    export STARSHIP_CONFIG="$HOME/.config/starship.toml"
    eval "$(starship init zsh)"
fi

if command -v direnv &> /dev/null; then
    eval "$(direnv hook zsh)"
fi

[[ $- == *i* ]] && command -v fastfetch &> /dev/null && fastfetch --config examples/12.jsonc

zcompile "$HOME/.zshrc"
zcompile "$HOME/.zshrc-macos"
