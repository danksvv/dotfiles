# ==============================================================================
# 1. MOTOR ASÍNCRONO (ZINIT)
# ==============================================================================
ZINIT_HOME="${HOME}/.local/share/zinit/zinit.git"
if [[ ! -d $ZINIT_HOME ]]; then
    mkdir -p "$(dirname $ZINIT_HOME)"
    git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi
source "${ZINIT_HOME}/zinit.zsh"

# ==============================================================================
# 2. PLUGINS CORE (Carga rápida sin bloquear)
# ==============================================================================
# Cargamos librerías esenciales de OMZ sin todo el framework
zinit light-mode for \
    OMZL::git.zsh \
    OMZL::history.zsh \
    OMZL::key-bindings.zsh \
    OMZL::completion.zsh \
    OMZP::git \
    zdharma-continuum/fast-syntax-highlighting \
    zsh-users/zsh-autosuggestions

# ==============================================================================
# 3. VARIABLES DE ENTORNO Y PATHS
# ==============================================================================
export LANG=es_ES.UTF-8
export EDITOR='nvim'
export GOPATH="$HOME/.local/share/go"
export PATH="$HOME/.scripts:/usr/local/opt/openjdk/bin:$PATH"
export PATH="/usr/local/opt/sqlite/bin:$PATH"
export PATH="/usr/local/opt/sqlite/bin:/usr/local/bin:/usr/local/sbin:$PATH"

# Gestión de secretos
[[ -f "$HOME/.zshrc_private" ]] && source "$HOME/.zshrc_private"

# Apariencia de ls
source "$HOME/.ls_themes.zsh"
set_ls_theme "neon"

# ==============================================================================
# 4. INYECTA ALIAS GLOBALES ZSH
# ==============================================================================

source $(brew --prefix)/etc/grc.zsh

# ==============================================================================
# 5. ALIAS Y FUNCIONES
# ==============================================================================
alias ls='lsd'
alias l='ls -ltr'
alias l.='ls -ltra | grep "^\."'
alias la='ls -lad .*'
alias lt='ls --tree'
alias vi='nvim'
alias x='exit'
alias tx='tmux'
alias zj='zellij'
alias ip="grc ip"
alias wcat='wezterm imgcat'
alias gitalias="git config --global --get-regexp alias"
alias fzfbat='fzf --preview="bat --theme=gruvbox-dark --color=always {}"'
alias fzfnvim='nvim $(fzf --preview="bat --theme=gruvbox-dark --color=always {}")'

# Función de limpieza de archivos
cf() {
    [[ $# -eq 0 ]] && { echo "Uso: cf <archivo1>..."; return 1; }
    for file in "$@"; do
        [[ -f "$file" ]] && { :> "$file"; echo "✔️ '$file' vaciado."; } || echo "⚠️ '$file' no existe."
    done
}

# Función de mantenimiento de Homebrew (Corregida)
brewup() {
    setopt localoptions errexit
    clear
    echo "==> [1/3] Sincronizando repositorios..."
    brew update

    echo "==> [2/3] Actualizando paquetes (Upgrade)..."
    brew upgrade

    echo "==> [3/3] Limpieza forzada de archivos huérfanos..."
    # Añadimos -s para limpiar el caché de descargas dañadas
    brew cleanup -s --prune=all
    
    echo "==> Verificando estado final..."
    brew doctor || true
    
    echo "==> Mantenimiento completado."
    read -q "?Presiona 'y' para ver fastfetch..." && fastfetch --config examples/12.jsonc
}

# ==============================================================================
# 6. CARGA DIFERIDA (TURBO MODE) - El secreto de la velocidad
# ==============================================================================
# Estas herramientas se inyectan 0.1s después de que el prompt esté listo.
zinit wait'0' lucid for \
    atinit'eval "$(zoxide init --cmd cd zsh)"' \
    atinit'eval "$(atuin init zsh)"' \
    atinit'eval "$(fnm env --use-on-cd --shell zsh)"' \
    zdharma-continuum/null

# SDKMAN bajo demanda (No ralentiza el inicio)
sdk() {
    unset -f sdk
    [[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]] && source "$HOME/.sdkman/bin/sdkman-init.sh"
    sdk "$@"
}

# ==============================================================================
# 7. PROMPT Y HOOKS FINALES
# ==============================================================================
# Starship se carga al final para asegurar que tiene prioridad visual
eval "$(starship init zsh)"
eval "$(direnv hook zsh)"

# Ejecutar fastfetch solo en sesiones interactivas
[[ $- == *i* ]] && [[ -x $(command -v fastfetch) ]] && fastfetch --config examples/12.jsonc

# Compilar este fichero a bytecode para la próxima vez
zcompile "$HOME/.zshrc"
